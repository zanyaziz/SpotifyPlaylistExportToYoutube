# Spotify API credentials
# Create an app at https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
# Redirect URIs — register EXACTLY these values in the dashboards
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8000/callback
YOUTUBE_REDIRECT_URI=http://127.0.0.1:8001/callback

# YouTube / Google API credentials
# Create credentials at https://console.cloud.google.com/
# Enable YouTube Data API v3, create OAuth 2.0 Client ID (Desktop app)
YOUTUBE_CLIENT_ID=your_youtube_client_id
YOUTUBE_CLIENT_SECRET=your_youtube_client_secret
